---
import GithubIcon from '@components/icons/github-icon.astro';
import LinkedinIcon from '@components/icons/linkedin-icon.astro';
import WhatsappIcon from '@components/icons/whatsapp-icon.astro';
import { Image } from 'astro:assets';
import { GITHUB_URL, LINKEDIN_URL, WHATSAPP_URL } from '@constants/urls.ts';
import { getI18n } from '@i18n/index';

const { currentLocale } = Astro;

const i18n = getI18n({ currentLocale });
const withBase = (path: string) => `${import.meta.env.BASE_URL.replace(/\/?$/, '/')}${path.replace(/^\/+/, '')}`;
---

<section class="home" id="home">
  <Image
    src={withBase('/me.webp')}
    alt={i18n.HERO_SECTION.IMAGE.ALT}
    class="profile"
    width={480}
    height={448}
    loading="eager"
    fetchpriority="high"
  />

  <div class="main-title">
    <h2 class="title">
      <span class="subtitle-name">
        {i18n.HERO_SECTION.SUBTITLE_EMPHASIS}
      </span>
    </h2>
    <span class="title-job">
      {i18n.HERO_SECTION.JOB_TITLE}
    </span>
    <div class="bottom">
      <a
        class="btn"
        href={withBase(i18n.HERO_SECTION.CV.PATH)}
        download={i18n.HERO_SECTION.CV.FILENAME}
        aria-label={i18n.HERO_SECTION.CV.ARIA_LABEL}
      >
        {i18n.HERO_SECTION.CV.BTN_TEXT}
      </a>
      <div class="social">
        <a target="_blank" href={GITHUB_URL} class="icon" aria-label="Github">
          <GithubIcon height={40} width={40} />
        </a>
        <a
          target="_blank"
          href={LINKEDIN_URL}
          class="icon"
          aria-label="Linkedin"
        >
          <LinkedinIcon height={40} width={40} />
        </a>
        <a
          target="_blank"
          href={WHATSAPP_URL}
          class="icon"
          aria-label="WhatsApp"
        >
          <WhatsappIcon height={40} width={40} />
        </a>
      </div>
    </div>
    <span class="scroll-down" aria-hidden="true"></span>
  </div>
</section>

<style>
  section.home {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    min-height: 100vh !important;
    margin: 0;
  }

  .scroll-down {
    margin-top: 8.5rem;
    width: 2.3rem;
    height: 2.9rem;
    position: relative;
    background: transparent;
    align-self: center;
    opacity: 0;
    animation:
      fadeInUp 0.8s ease-out 0.35s forwards,
      chevron-stack-float 2s ease-in-out 1.15s infinite;
  }

  .scroll-down::before {
    content: "";
    position: absolute;
    top: 0.15rem;
    left: 50%;
    width: 0.9rem;
    height: 0.9rem;
    border-right: 2px solid var(--font-color-2);
    border-bottom: 2px solid var(--font-color-2);
    transform: translateX(-50%) rotate(45deg);
    filter: drop-shadow(0 1px 4px rgba(0, 0, 0, 0.45));
    animation: chevron-top 1.8s ease-in-out 1.15s infinite;
  }

  .scroll-down::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 1.18rem;
    width: 0.9rem;
    height: 0.9rem;
    border-right: 2px solid var(--font-color-2);
    border-bottom: 2px solid var(--font-color-2);
    transform: translateX(-50%) rotate(45deg);
    opacity: 0.75;
    filter: drop-shadow(0 1px 4px rgba(0, 0, 0, 0.45));
    animation: chevron-bottom 1.8s ease-in-out 1.45s infinite;
  }

  .main-title {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.3rem;
  }

  .main-title .bottom {
    margin-top: 1.2rem;
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 1rem;
  }

  .main-title .bottom .social {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
  }

  .main-title .bottom .social a {
    text-decoration: none;
    transition: 0.4s;
    color: var(--secondary-color);
    font-size: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .main-title .bottom .social a:hover {
    color: var(--primary-color);
  }

  h1.title,
  h2.title {
    font-weight: bold;
    font-size: 64px;
    cursor: default;
    color: var(--font-color);
  }

  h2.title {
    font-size: 60px;
  }

  h1.title span {
    display: inline-block;
    position: relative;
    transition: 0.6s;
  }

  h1.title:hover > span {
    animation: move 0.6s ease-in-out;
  }

  @keyframes move {
    0% {
      transform: translateX(0px);
    }
    25% {
      transform: translateX(-7px);
      rotate: -7deg;
    }
    50% {
      transform: translateX(7px);
      rotate: 7deg;
    }
    100% {
      transform: translateX(0);
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes chevron-stack-float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(5px);
    }
  }

  @keyframes chevron-top {
    0% {
      opacity: 0.18;
      transform: translateX(-50%) translateY(0) rotate(45deg);
    }
    25% {
      opacity: 0.92;
    }
    50% {
      opacity: 0.45;
      transform: translateX(-50%) translateY(2px) rotate(45deg);
    }
    75% {
      opacity: 0.95;
    }
    100% {
      opacity: 0.18;
      transform: translateX(-50%) translateY(0) rotate(45deg);
    }
  }

  @keyframes chevron-bottom {
    0%,
    100% {
      opacity: 0.2;
      transform: translateX(-50%) translateY(0) rotate(45deg);
    }
    30% {
      opacity: 0.9;
    }
    50% {
      opacity: 0.4;
      transform: translateX(-50%) translateY(4px) rotate(45deg);
    }
    80% {
      opacity: 0.88;
    }
  }

  h2.title span.subtitle-name {
    font-size: 64;
    font-weight: bold;
    color: var(--primary-color);
  }

  span.title-job {
    font-size: 32px;
    font-weight: bold;
    color: var(--font-color-2);
  }

  img {
    object-fit: cover;
    width: 30rem;
    height: 28rem;
    border-radius: 63% 37% 48% 52% / 60% 57% 43% 40%;
    border: 3px solid var(--primary-color);
    box-shadow: 0 15px 25px rgba(0, 0, 0, 0.3);
    background: var(--primary-color);
  }

  @media (max-width: 1024px) {
    img.profile {
      width: 28rem;
      height: 23rem;
    }
  }

  @media (max-width: 900px) {
    img.profile {
      width: 28rem;
      height: 23rem;
    }
  }

  @media (max-width: 768px) {
    section.home {
      flex-direction: column;
      justify-content: center;
      gap: 1rem;
      padding-top: max(5rem);
    }
    .main-title {
      text-align: center;
    }
    h1.title,
    h2.title {
      font-size: 52px;
      margin: 0;
    }
    span.title-job {
      font-size: 28px;
    }

    img.profile {
      width: 18rem;
      height: 18rem;
    }
    .main-title .bottom {
      justify-content: center;
    }

    .scroll-down {
      margin-top: 1.4rem;
      align-self: center;
    }
  }

  @media (max-width: 480px) {
    h1.title,
    h2.title {
      font-size: 42px;
    }
    span.title-job {
      font-size: 28px;
    }

    img.profile {
      width: 14rem;
      height: 14rem;
    }

    .scroll-down {
      width: 2rem;
      height: 2.5rem;
    }

    .scroll-down::before,
    .scroll-down::after {
      width: 0.76rem;
      height: 0.76rem;
    }

    .scroll-down::after {
      top: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-down {
      opacity: 1;
      animation: none;
    }

    .scroll-down::before,
    .scroll-down::after {
      animation: none;
    }
  }
</style>
